# =====================================================================
# Rebrandable Gym Website - Apache / LiteSpeed configuration
# Compatible with shared hosting (cPanel, Plesk), VPS (Apache/Nginx)
# =====================================================================

# Ensure PHP files are processed (fixes "plain text" issue on some hosts)
<IfModule mod_mime.c>
    AddType application/x-httpd-php .php
</IfModule>

# Alternative PHP handler for CGI/FastCGI hosts (uncomment if above doesn't work)
# AddHandler application/x-httpd-php .php
# AddHandler application/x-httpd-php74 .php
# AddHandler application/x-httpd-php80 .php
# AddHandler application/x-httpd-php81 .php
# AddHandler application/x-httpd-php82 .php
# AddHandler application/x-httpd-php83 .php

# Default document
DirectoryIndex index.php index.html

<IfModule mod_rewrite.c>
    RewriteEngine On

    # Serve dynamic sitemap.xml and robots.txt
    RewriteRule ^sitemap\.xml$ sitemap.php [L]
    RewriteRule ^robots\.txt$ robots.php [L]
</IfModule>

# Block access to sensitive files only (NOT folders)
<FilesMatch "^(\..*|database\.sql|install\.lock)$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order deny,allow
        Deny from all
    </IfModule>
</FilesMatch>

# Basic caching for static assets
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType image/jpeg "access plus 1 month"
    ExpiresByType image/png "access plus 1 month"
    ExpiresByType image/webp "access plus 1 month"
    ExpiresByType text/css "access plus 1 week"
    ExpiresByType application/javascript "access plus 1 week"
</IfModule>

# Gzip compression
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/css application/javascript text/xml application/xml
</IfModule>
