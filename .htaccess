# =====================================================================
# Rebrandable Gym Website - Apache configuration
# =====================================================================

<IfModule mod_rewrite.c>
    RewriteEngine On

    # Serve dynamic sitemap.xml and robots.txt
    RewriteRule ^sitemap\.xml$ sitemap.php [L]
    RewriteRule ^robots\.txt$ robots.php [L]
</IfModule>

# Default document
DirectoryIndex index.php

# Block access to sensitive files
<FilesMatch "(^\.|database\.sql|config\.php~|config\.local\.php|install\.lock|composer\.(json|lock))">
    Require all denied
</FilesMatch>

# Basic caching for static assets
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType image/jpeg "access plus 1 month"
    ExpiresByType image/png "access plus 1 month"
    ExpiresByType image/webp "access plus 1 month"
    ExpiresByType text/css "access plus 1 week"
    ExpiresByType application/javascript "access plus 1 week"
</IfModule>

# Gzip compression
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/css application/javascript text/xml application/xml
</IfModule>
